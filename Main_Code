class expense{
    double amt;
    String itemi;
    String category;
    LocalDate tdate; // today date 
    LocalTime ntime; //time of item purchased

    public expense(double amt,String itemi,String category,LocalDate tdate,LocalTime ntime){
        this.amt = amt;
        this.itemi = itemi;
        this.category = category;
        this.tdate = tdate;
        this.ntime = ntime;
    }

}
